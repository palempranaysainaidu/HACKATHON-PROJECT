# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/eventos?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# Email (Gmail SMTP)
EMAIL_USER=yourgmail@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
EVENT_SITE_URL=http://localhost:5174

# Production URLs (fill when deploying)
PROD_CLIENT_URL=https://eventos.vercel.app
PROD_EVENT_SITE_URL=https://eventos-site.vercel.app
